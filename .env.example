# Required
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override the model (default: openai/gpt-oss-120b:free)
# OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Gemini (commented out — switch back by restoring these and updating pipeline.py)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# Optional: LangSmith tracing (bonus +5 pts)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=ticket-triage
